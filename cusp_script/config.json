  "baselines_placeholder": {
    "note": "Baseline hyperparameter stubs; fill when you add models. train.py currently supports --model cusp only.",
    "GCN": {
      "layers": 2,
      "hidden_dim": 64,
      "activation": "ReLU",
      "dropout": 0.5,
      "lr": 0.01,
      "weight_decay": 0.0005,
      "epochs": 200
    },
    "GAT": {
      "layers": 2,
      "heads": 8,
      "hidden_dim": 8,
      "activation": "ELU",
      "dropout": 0.6,
      "lr": 0.005,
      "weight_decay": 0.0005,
      "epochs": 200
    },
    "GraphSAGE": {
      "layers": 2,
      "hidden_dim": 64,
      "aggregator": "mean",
      "activation": "ReLU",
      "lr": 0.01,
      "weight_decay": 0.0005,
      "epochs": 200
    },
    "APPNP": {
      "layers": 2,
      "hidden_dim": 64,
      "alpha": 0.1,
      "K": 10,
      "activation": "ReLU",
      "lr": 0.01,
      "weight_decay": 0.0005,
      "epochs": 200
    },
    "MLP": {
      "layers": 2,
      "hidden_dim": 64,
      "activation": "ReLU",
      "dropout": 0.5,
      "lr": 0.01,
      "weight_decay": 0.0005,
      "epochs": 200
    },
    "Node2Vec": {
      "embedding_dim": 128,
      "walk_length": 20,
      "context_size": 10,
      "walks_per_node": 10,
      "lr": 0.01,
      "epochs": 100
    }
  }
