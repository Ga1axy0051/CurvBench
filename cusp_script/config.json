{
  "schema": "cusp_experiment_config_v1",
  "description": "Default CUSP training hyperparameters, Table2Graph paths, and baseline placeholders (this repo implements CUSP only).",
  "experiment": {
    "default_seeds": [0, 1, 2, 3, 4],
    "recommended_cli": "python train.py --config config.json --dataset <NAME> --task node_classification --export_dir results/<NAME>_nc --seeds 0 1 2 3 4",
    "metrics": {
      "node_classification": ["accuracy", "f1_macro", "f1_micro", "f1_weighted"],
      "link_prediction": ["auc", "ap"],
      "efficiency": [
        "total_train_loop_sec",
        "avg_sec_per_epoch",
        "total_test_eval_sec",
        "total_train_step_sec",
        "total_eval_during_train_sec"
      ]
    }
  },
  "cusp_architecture": {
    "gnn_inner_activation": "ReLU",
    "output": "Linear + log_softmax",
    "propagation": "GPR / CuspGNN (see --ppnp, --K, --alpha, --Init)",
    "notes": "Layer sizes follow manifold_config (e.g. H16H16S16E16) and filter count K."
  },
  "table2graph_datasets": {
    "root_default": "data/exptable2graph",
    "Carcinogenesis": {
      "folder": "Carcinogenesis_data",
      "files": {
        "heterogeneous": "Carcinogenesis_HeteroGraph.pt",
        "unified_homogeneous": "unified_data.pt"
      },
      "cusp_training": {
        "epochs": 100,
        "lr": 0.001,
        "weight_decay": 0.0005,
        "dropout": 0.5,
        "dprate": 0.5,
        "optimizer": "adam",
        "K": 10,
        "alpha": 0.1,
        "Init": "PPR",
        "manifold_config": "H16H16S16E16",
        "d_f": 64,
        "num_frequencies": 16
      }
    },
    "Hockey": {
