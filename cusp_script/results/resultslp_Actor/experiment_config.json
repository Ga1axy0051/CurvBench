{
  "config_json": "config.json",
  "data_root": "/data/hxz/wqx/cusp-main/data",
  "dataset": "Actor",
  "task": "link_prediction",
  "model": "cusp",
  "manifold_config": "H16H16S16E16",
  "K_GPR": 10,
  "num_propagation_orders": 11,
  "alpha_GPR": 0.1,
  "Init_GPR_weights": "PPR",
  "Gamma_GPR": null,
  "d_f_curvature": 64,
  "num_frequencies": 16,
  "dropout": 0.5,
  "dprate": 0.5,
  "optimizer": "adam",
  "learning_rate": 0.001,
  "weight_decay": 0.0005,
  "epochs": 500,
  "early_stopping_patience": 100,
  "early_stopping_min_delta": 0.0,
  "lr_scheduler": {
    "type": "StepLR",
    "step_size": 50,
    "gamma": 0.1
  },
  "loss": "link_prediction (BCE with logits)",
  "activation_in_cusp_gnn": "ReLU",
  "output_layer": "Linear + log_softmax (node classification)",
  "use_cusp_laplacian": false,
  "use_curvature_encoding": false,
  "use_cusp_pooling": false,
  "euclidean_variant": false,
  "ricci_alpha": 0.5,
  "allow_download": false,
  "device": "cuda",
  "notes": "CUSP 不是「堆叠 L 层 GNN」；滤波器阶数由 K 与 GPR 给出，流形维度由 manifold_config 解析。"
}